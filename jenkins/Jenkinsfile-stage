pipeline {
    agent any

    environment {
        DOCKER_REGISTRY = 'selimhorri'
        VERSION = "${BUILD_NUMBER}"
        NAMESPACE = 'ecommerce-stage'
        SERVICES = 'api-gateway,user-service,product-service,order-service,payment-service,shipping-service'
        MAVEN_OPTS = '-Xmx1024m'
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    echo "Cloning repository for STAGING..."
                    checkout scm
                    sh '''
                    echo "Commit Info:"
                    git log -1 --pretty=format:"%h - %an (%ae): %s"
                    echo "\nBranch: $(git branch --show-current)"
                    '''
                }
            }
        }

        stage('Build & Unit Tests') {
            parallel {
                stage('Build API Gateway') {
                    steps {
                        script { buildAndTest('api-gateway') }
                    }
                }
                stage('Build User Service') {
                    steps {
                        script { buildAndTest('user-service') }
                    }
                }
                stage('Build Product Service') {
                    steps {
                        script { buildAndTest('product-service') }
                    }
                }
                stage('Build Order Service') {
                    steps {
                        script { buildAndTest('order-service') }
                    }
                }
                stage('Build Payment Service') {
                    steps {
                        script { buildAndTest('payment-service') }
                    }
                }
                stage('Build Shipping Service') {
                    steps {
                        script { buildAndTest('shipping-service') }
                    }
                }
            }
        }

        stage('Test Reports') {
            steps {
                script {
                    echo "Collecting test reports..."
                    junit '**/target/surefire-reports/*.xml'

                    // Publicar reportes de cobertura si existen
                    publishHTML([
                        allowMissing: true,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'target/site/jacoco',
                        reportFiles: 'index.html',
                        reportName: 'Code Coverage Report'
                    ])
                }
            }
        }

        stage('Build Docker Images') {
            steps {
                script {
                    echo "Building Docker images for STAGE..."
                    def services = env.SERVICES.split(',')
                    services.each { service ->
                        sh """
                            docker build \
                                --build-arg SERVICE_NAME=${service} \
                                -t ${DOCKER_REGISTRY}/${service}-ecommerce-boot:${VERSION} \
                                -t ${DOCKER_REGISTRY}/${service}-ecommerce-boot:stage-latest \
                                -f docker/Dockerfile-springboot \
                                .
                        """
                    }
                }
            }
        }

        stage('Security Scan') {
            steps {
                script {
                    echo "Running security scans..."
                    def services = env.SERVICES.split(',')
                    services.each { service ->
                        sh """
                            # Trivy scan (si está instalado)
                            if command -v trivy &> /dev/null; then
                                trivy image --severity HIGH,CRITICAL \
                                    ${DOCKER_REGISTRY}/${service}-ecommerce-boot:${VERSION} || true
                            fi
                        """
                    }
                }
            }
        }

        stage('Push to Registry') {
            steps {
                script {
                    echo "Pushing images to Docker Hub..."
                    withDockerRegistry([credentialsId: 'dockerhub-credentials', url: '']) {
                        def services = env.SERVICES.split(',')
                        services.each { service ->
                            sh """
                                docker push ${DOCKER_REGISTRY}/${service}-ecommerce-boot:${VERSION}
                                docker push ${DOCKER_REGISTRY}/${service}-ecommerce-boot:stage-latest
                            """
                        }
                    }
                }
            }
        }

        stage('Deploy to Kubernetes Stage') {
            steps {
                script {
                    echo "Deploying to Kubernetes ${NAMESPACE}..."

                    // Crear namespace
                    sh "kubectl create namespace ${NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -"

                    // Aplicar configuraciones
                    sh "kubectl apply -f kubernetes/stage/configmap.yaml"

                    // Desplegar servicios core primero
                    sh """
                        kubectl apply -f kubernetes/stage/zipkin-deployment.yaml
                        kubectl apply -f kubernetes/stage/service-discovery-deployment.yaml
                        kubectl apply -f kubernetes/stage/cloud-config-deployment.yaml

                        # Esperar a que estén listos
                        kubectl wait --for=condition=available --timeout=5m \
                            deployment/zipkin -n ${NAMESPACE}
                        kubectl wait --for=condition=available --timeout=5m \
                            deployment/service-discovery -n ${NAMESPACE}
                        kubectl wait --for=condition=available --timeout=5m \
                            deployment/cloud-config -n ${NAMESPACE}
                    """

                    // Desplegar microservicios
                    def services = env.SERVICES.split(',')
                    services.each { service ->
                        sh """
                            # Actualizar imagen
                            kubectl set image deployment/${service} \
                                ${service}=${DOCKER_REGISTRY}/${service}-ecommerce-boot:${VERSION} \
                                -n ${NAMESPACE} || \
                            kubectl apply -f kubernetes/stage/${service}-deployment.yaml

                            # Esperar rollout
                            kubectl rollout status deployment/${service} -n ${NAMESPACE} --timeout=5m
                        """
                    }
                }
            }
        }

        stage('Integration Tests') {
            steps {
                script {
                    echo "Running Integration Tests..."

                    // Obtener URL del API Gateway
                    def apiGatewayUrl = sh(
                        script: "kubectl get svc api-gateway -n ${NAMESPACE} -o jsonpath='{.spec.clusterIP}'",
                        returnStdout: true
                    ).trim()

                    // Ejecutar tests de integración
                    dir('tests/integration') {
                        sh """
                            export API_GATEWAY_URL=http://${apiGatewayUrl}:8080
                            mvn clean test -Dtest=*IntegrationTest
                        """
                    }

                    // Publicar resultados
                    junit 'tests/integration/target/surefire-reports/*.xml'
                }
            }
        }

        stage('E2E Tests') {
            steps {
                script {
                    echo "Running E2E Tests..."

                    def apiGatewayUrl = sh(
                        script: "kubectl get svc api-gateway -n ${NAMESPACE} -o jsonpath='{.spec.clusterIP}'",
                        returnStdout: true
                    ).trim()

                    dir('tests/e2e') {
                        sh """
                            export API_GATEWAY_URL=http://${apiGatewayUrl}:8080
                            mvn clean test
                        """
                    }

                    junit 'tests/e2e/target/surefire-reports/*.xml'
                }
            }
        }

        stage('Performance Tests') {
            steps {
                script {
                    echo "Running Performance Tests with Locust..."

                    def apiGatewayUrl = sh(
                        script: "kubectl get svc api-gateway -n ${NAMESPACE} -o jsonpath='{.spec.clusterIP}'",
                        returnStdout: true
                    ).trim()

                    dir('tests/performance') {
                        sh """
                            # Instalar dependencias
                            pip3 install -r requirements.txt

                            # Ejecutar Locust
                            locust -f locustfile.py \
                                --host=http://${apiGatewayUrl}:8080 \
                                --users=50 \
                                --spawn-rate=5 \
                                --run-time=3m \
                                --html=locust-report-${BUILD_NUMBER}.html \
                                --csv=locust-results-${BUILD_NUMBER} \
                                --headless
                        """
                    }

                    // Publicar reporte HTML
                    publishHTML([
                        allowMissing: false,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'tests/performance',
                        reportFiles: "locust-report-${BUILD_NUMBER}.html",
                        reportName: 'Locust Performance Report'
                    ])

                    // Archivar resultados CSV
                    archiveArtifacts artifacts: "tests/performance/locust-results-${BUILD_NUMBER}*.csv"
                }
            }
        }

        stage('Quality Gate') {
            steps {
                script {
                    echo "Evaluating Quality Gate..."

                    // Leer resultados de Locust
                    def statsFile = "tests/performance/locust-results-${BUILD_NUMBER}_stats.csv"

                    if (fileExists(statsFile)) {
                        def stats = readCSV file: statsFile

                        // Validar métricas críticas
                        def failureRate = stats[1][9].toFloat() // Columna de failures
                        def avgResponseTime = stats[1][5].toFloat() // Avg response time

                        echo "Metricas:"
                        echo "  - Tasa de errores: ${failureRate}%"
                        echo "  - Tiempo promedio respuesta: ${avgResponseTime}ms"

                        // Quality Gate
                        if (failureRate > 5.0) {
                            error("Quality Gate FAILED: Tasa de errores > 5%")
                        }
                        if (avgResponseTime > 2000) {
                            unstable("Warning: Tiempo de respuesta > 2s")
                        }
                    }
                }
            }
        }

        stage('Smoke Tests') {
            steps {
                script {
                    echo "Running Smoke Tests..."
                    sh '''
                        # Verificar salud de todos los servicios
                        SERVICES_ARRAY=(${SERVICES//,/ })

                        for service in "${SERVICES_ARRAY[@]}"; do
                            echo "Checking $service..."
                            SVC_IP=$(kubectl get svc $service -n ${NAMESPACE} -o jsonpath='{.spec.clusterIP}')

                            # Obtener puerto del servicio
                            case $service in
                                api-gateway) PORT=8080 ;;
                                user-service) PORT=8700 ;;
                                product-service) PORT=8500 ;;
                                order-service) PORT=8300 ;;
                                payment-service) PORT=8400 ;;
                                shipping-service) PORT=8600 ;;
                            esac

                            # Health check
                            curl -f http://${SVC_IP}:${PORT}/actuator/health || exit 1
                            echo "$service is healthy"
                        done
                    '''
                }
            }
        }
    }

    post {
        success {
            script {
                echo "Pipeline STAGE completed successfully!"

                // Notificaciones
                slackSend(
                    color: 'good',
                    message: """
                        STAGE Deploy Success
                        Build: #${BUILD_NUMBER}
                        Version: ${VERSION}
                        Services: ${SERVICES}
                        Namespace: ${NAMESPACE}
                    """
                )
            }
        }
        failure {
            script {
                echo "Pipeline STAGE failed!"
                slackSend(
                    color: 'danger',
                    message: """
                        STAGE Deploy Failed
                        Build: #${BUILD_NUMBER}
                        Check: ${BUILD_URL}
                    """
                )
            }
        }
        always {
            script {
                // Limpiar workspace
                cleanWs()

                // Limpiar imágenes Docker locales
                sh '''
                    docker image prune -f
                    docker container prune -f
                '''
            }
        }
    }
}

// Helper function para build y test
def buildAndTest(serviceName) {
    echo "Building and testing ${serviceName}..."
    dir(serviceName) {
        sh '''
            mvn clean test package
            mvn jacoco:report || true
        '''
    }
}
