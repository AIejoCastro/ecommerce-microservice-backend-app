// jenkins/Jenkinsfile-dev
pipeline {
    agent any
    
    triggers {
        // GitHub webhook trigger - requires webhook configuration in GitHub
        githubPush()
        // Poll SCM every 5 minutes as backup (only triggers if changes detected)
        pollSCM('H/5 * * * *')
    }
    
    environment {
        DOCKER_REGISTRY = 'alejocastro'
        VERSION = "${BUILD_NUMBER}"
        NAMESPACE = 'ecommerce-dev'
        // Infrastructure services must be deployed first
        INFRA_SERVICES = 'cloud-config,service-discovery'
        // Application services depend on infrastructure
        APP_SERVICES = 'api-gateway,user-service,product-service,order-service,payment-service,shipping-service'
        SERVICES = 'cloud-config,service-discovery,api-gateway,user-service,product-service,order-service,payment-service,shipping-service'
        APP_VERSION = '0.1.0'
        EXPECTED_BRANCH = 'dev'
        KUBE_CONFIG_CREDENTIALS_ID = 'kubeconfig-dev'
    }
    
    stages {
        stage('Checkout') {
            steps {
                script {
                    echo "Cloning repository..."
                    checkout scm
                    validateBranch(env.EXPECTED_BRANCH)
                    sh 'git log -1 --pretty=format:"%h - %an: %s"'
                }
            }
        }
        
        stage('Build Services') {
            parallel {
                stage('Build Cloud Config') {
                    steps {
                        script {
                            buildService('cloud-config')
                        }
                    }
                }
                stage('Build Service Discovery') {
                    steps {
                        script {
                            buildService('service-discovery')
                        }
                    }
                }
                stage('Build API Gateway') {
                    steps {
                        script {
                            buildService('api-gateway')
                        }
                    }
                }
                stage('Build User Service') {
                    steps {
                        script {
                            buildService('user-service')
                        }
                    }
                }
                stage('Build Product Service') {
                    steps {
                        script {
                            buildService('product-service')
                        }
                    }
                }
                stage('Build Order Service') {
                    steps {
                        script {
                            buildService('order-service')
                        }
                    }
                }
                stage('Build Payment Service') {
                    steps {
                        script {
                            buildService('payment-service')
                        }
                    }
                }
                stage('Build Shipping Service') {
                    steps {
                        script {
                            buildService('shipping-service')
                        }
                    }
                }
            }
        }
        
        stage('Build Docker Images') {
            steps {
                script {
                    echo "Building Docker images for all services..."
                    def services = env.SERVICES.split(',')
                    services.each { service ->
                        sh """
                            docker build \
                                --build-arg PROJECT_VERSION=${APP_VERSION} \
                                -t ${DOCKER_REGISTRY}/${service}-ecommerce-boot:${VERSION} \
                                -t ${DOCKER_REGISTRY}/${service}-ecommerce-boot:dev-latest \
                                -f ${service}/Dockerfile \
                                ${service}
                        """
                    }
                }
            }
        }
        
        stage('Push to Registry') {
            steps {
                script {
                    echo "Pushing images to Docker Hub..."
                    withDockerRegistry([credentialsId: 'dockerhub-credentials', url: '']) {
                        def services = env.SERVICES.split(',')
                        services.each { service ->
                            sh """
                                docker push ${DOCKER_REGISTRY}/${service}-ecommerce-boot:${VERSION}
                                docker push ${DOCKER_REGISTRY}/${service}-ecommerce-boot:dev-latest
                            """
                        }
                    }
                }
            }
        }
        
        stage('Deploy to Kubernetes Dev') {
            steps {
                script {
                    echo "Deploying to Kubernetes ${NAMESPACE}..."
                    withKubeConfig([credentialsId: env.KUBE_CONFIG_CREDENTIALS_ID]) {
                        sh 'kubectl config current-context'

                        // Crear namespace si no existe
                        sh "kubectl create namespace ${NAMESPACE} --dry-run=client -o yaml | kubectl apply --validate=false -f -"
                        
                        // Aplicar ConfigMaps
                        sh "kubectl apply --validate=false -f kubernetes/dev/configmap.yaml"
                        
                        // Deploy infrastructure services first
                        echo "Deploying infrastructure services..."
                        def infraServices = env.INFRA_SERVICES.split(',')
                        infraServices.each { service ->
                            sh """
                                kubectl set image deployment/${service} \
                                    ${service}=${DOCKER_REGISTRY}/${service}-ecommerce-boot:${VERSION} \
                                    -n ${NAMESPACE} || \
                                kubectl apply --validate=false -f kubernetes/dev/${service}-deployment.yaml
                                
                                kubectl rollout status deployment/${service} -n ${NAMESPACE} --timeout=5m
                            """
                        }
                        
                        // Wait a bit for services to be fully ready
                        echo "Waiting for infrastructure services to stabilize..."
                        sh "sleep 15"
                        
                        // Deploy application services
                        echo "Deploying application services..."
                        def appServices = env.APP_SERVICES.split(',')
                        appServices.each { service ->
                            sh """
                                kubectl set image deployment/${service} \
                                    ${service}=${DOCKER_REGISTRY}/${service}-ecommerce-boot:${VERSION} \
                                    -n ${NAMESPACE} || \
                                kubectl apply --validate=false -f kubernetes/dev/${service}-deployment.yaml
                                
                                kubectl rollout status deployment/${service} -n ${NAMESPACE} --timeout=5m
                            """
                        }
                    }
                }
            }
        }
        
        stage('Smoke Tests') {
            steps {
                script {
                    echo "🧪 Running smoke tests..."
                    withKubeConfig([credentialsId: env.KUBE_CONFIG_CREDENTIALS_ID]) {
                        sh '''
                            set +e  # Don't exit on first error
                            
                            # Function to test endpoint with retries
                            test_endpoint() {
                                local service_name=$1
                                local service_url=$2
                                local max_attempts=10
                                local attempt=1
                                
                                echo "Testing ${service_name}..."
                                while [ $attempt -le $max_attempts ]; do
                                    echo "  Attempt ${attempt}/${max_attempts}..."
                                    if curl -sf --connect-timeout 5 --max-time 10 "${service_url}" > /dev/null 2>&1; then
                                        echo "  ✅ ${service_name} is healthy!"
                                        return 0
                                    fi
                                    echo "  ⏳ Waiting 10 seconds before retry..."
                                    sleep 10
                                    attempt=$((attempt + 1))
                                done
                                
                                echo "  ❌ ${service_name} health check failed after ${max_attempts} attempts"
                                return 1
                            }
                            
                            # Wait for services to fully start
                            echo "Waiting for services to stabilize..."
                            sleep 30
                            
                            # Test API Gateway
                            GATEWAY_URL=$(kubectl get svc api-gateway -n ${NAMESPACE} -o jsonpath='{.spec.clusterIP}')
                            test_endpoint "API Gateway" "http://${GATEWAY_URL}:8080/actuator/health"
                            GATEWAY_RESULT=$?
                            
                            # Test User Service (with context path)
                            USER_URL=$(kubectl get svc user-service -n ${NAMESPACE} -o jsonpath='{.spec.clusterIP}')
                            test_endpoint "User Service" "http://${USER_URL}:8700/user-service/actuator/health"
                            USER_RESULT=$?
                            
                            # Check results
                            if [ $GATEWAY_RESULT -eq 0 ] && [ $USER_RESULT -eq 0 ]; then
                                echo "🎉 All smoke tests passed!"
                                exit 0
                            else
                                echo "💥 Some smoke tests failed!"
                                kubectl get pods -n ${NAMESPACE}
                                exit 1
                            fi
                        '''
                    }
                }
            }
        }
    }
    
    post {
        success {
            echo "Pipeline DEV completed successfully!"
        }
        failure {
            echo "Pipeline DEV failed!"
        }
        always {
            cleanWs()
        }
    }
}

// Función helper para build
def buildService(serviceName) {
    echo "Building ${serviceName}..."
    dir(serviceName) {
        sh 'chmod +x mvnw'
        sh './mvnw clean package -DskipTests'
    }
}

// Abort early if pipeline runs from the wrong branch to keep environment isolation intact
def validateBranch(expectedBranch) {
    def branch = env.BRANCH_NAME ?: env.GIT_BRANCH
    if (!branch || branch == 'HEAD') {
        branch = sh(returnStdout: true, script: 'git rev-parse --abbrev-ref HEAD').trim()
    }
    if (branch?.contains('/')) {
        branch = branch.tokenize('/').last()
    }
    if (!branch || branch != expectedBranch) {
        error "Detected branch '${branch ?: 'unknown'}'; this pipeline must run on '${expectedBranch}'."
    }
}